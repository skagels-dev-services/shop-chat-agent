# -----------------------------------------------------------------------------
# Example of environment file for the shop-chat-agent app.
# Save a copy of this file as ./.env and fill in the values for your environment.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# shop-chat-agent app: Shopify Storefront API
# -----------------------------------------------------------------------------
REDIRECT_URL=https://localhost:3458/auth/callback
SHOPIFY_API_KEY=

# -----------------------------------------------------------------------------
# AI Integration (assumes you have a Claude subscription)
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=

# -----------------------------------------------------------------------------
# shop-customer-manager
# -----------------------------------------------------------------------------
# Admin API — required for dev scripts (list-customers, set-customer-metafields, etc.)
# Create a custom app in Shopify Admin → Settings → Apps → Develop apps
# Grant read_customers (and write_customers to set metafields) scope
SHOPIFY_STORE_DOMAIN=
# Example: SHOPIFY_STORE_DOMAIN=a1-outfitters-2.myshopify.com
#SHOPIFY_ADMIN_TOKEN

# -----------------------------------------------------------------------------
# shop-customer-mgr
#   Client ID and secret (for OAuth flow in the React app, 
#   not needed for the dev scripts which use the admin token directly)
# -----------------------------------------------------------------------------
#SHOPIFY_CUSTOMER_MGR_API_KEY=
#SHOPIFY_CUSTOMER_MGR_STORE_TOKEN=shpss_...

# Use the App automation token (admin token is an old terminology)
#SHOPIFY_CUSTOMER_MGR_AUTO_TOKEN=atkn_...

# Not sure how to create the admin token for customer mgr app - 
#   Online instructions are for older UI.
#   Claude claims auto token is the new term for admin token for the API calls in the scripts, 
#   but script execution still gets errors; expects a token that starts with 'shpat_'
#SHOPIFY_CUSTOMER_MGR_ADMIN_TOKEN=shpat_...

# -----------------------------------------------------------------------------
# Voice Analysis (server-side STT + optional demographics)
# -----------------------------------------------------------------------------
# To enable: set VOICE_ANALYSIS_ENABLED=true and enable "Server-Side Voice Analysis" in the theme block settings
#VOICE_ANALYSIS_ENABLED=false
VOICE_ANALYSIS_ENABLED=true
VOICE_PROVIDER=deepgram

# -----------------------------------------------------------------------------
# Voice Demographics (Optional) 
# -----------------------------------------------------------------------------
#      Requires additional provider that supports demographics
#      - Currently only Deepgram; adds cost
#
# When enabled, the agent will attempt to infer the customer's age range.
# When using demographics, you must use AssemblyAI as the provider (provide AssemblyAI API key below)
VOICE_DEMOGRAPHICS_ENABLED=false
# VOICE_DEMOGRAPHICS_ENABLED=true

# -----------------------------------------------------------------------------
# Deepgram - The default provider for voice analysis, must be used if demographics is enabled. 
#            Use the free tier for development, which includes 500 minutes of transcription per month. 
#            Sign up at https://deepgram.com/ to get your API key.
# -----------------------------------------------------------------------------
# Deepgram API Keys: 
# - Agenscience Integration Key (default role): 
# - Agenscience Member Key (elevated role with access to demographics): 
# Use Member Key if demographics is enabled
#DEEPGRAM_API_KEY=

# -----------------------------------------------------------------------------
# AssemblyAI: Agenscience Integration Key: 
# -----------------------------------------------------------------------------
# **Note:** The current implementation returns `sentiment` only. Full age/gender 
#           demographic inference requires AssemblyAI's Universal-2 model 
#           with Speaker Analysis add-ons enabled on a paid plan.
#
# Required if VOICE_DEMOGRAPHICS_ENABLED=true
#ASSEMBLYAI_API_KEY=