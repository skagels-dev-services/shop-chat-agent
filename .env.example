CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
REDIRECT_URL=https://localhost:3458/auth/callback
SHOPIFY_API_KEY=YOUR_APP_CLIENT_ID

# Admin API — required for dev scripts (list-customers, set-customer-metafields, etc.)
# Create a custom app in Shopify Admin → Settings → Apps → Develop apps
# Grant read_customers (and write_customers to set metafields) scope
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...

# Phase 3: Voice Analysis (server-side STT + optional demographics)
# Set VOICE_ANALYSIS_ENABLED=true and enable "Server-Side Voice Analysis" in the theme block settings
VOICE_ANALYSIS_ENABLED=false
VOICE_PROVIDER=deepgram
VOICE_DEMOGRAPHICS_ENABLED=false
DEEPGRAM_API_KEY=...
ASSEMBLYAI_API_KEY=...   # only needed if VOICE_DEMOGRAPHICS_ENABLED=true
